<Window x:Class="ToolShell.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:logViewer="clr-namespace:ToolCore.Logging.Wpf.Controls;assembly=ToolCore.Logging.Wpf"
        Title="Tool Shell" Height="800" Width="400">
    <Grid>
        <Button Content="Test Log"
                Width="120"
                Height="35"
                Click="TestLogButton_Click"
                HorizontalAlignment="Center"
                VerticalAlignment="Top" Margin="0,32,0,0"/>
        <Button Content="Debug Log"
            Width="120"
            Height="35"
            Click="DebugLogButton_Click"
            HorizontalAlignment="Center"
            VerticalAlignment="Top" Margin="0,92,0,0"/>
        <logViewer:LiveLogViewer x:Name="AppLogViewer" Height="220" VerticalAlignment="Bottom" />
    </Grid>
</Window>