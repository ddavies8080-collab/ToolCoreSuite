<Window x:Class="ToolShell.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:logViewer="clr-namespace:ToolCore.Logging.Wpf.Controls;assembly=ToolCore.Logging.Wpf"
        Title="Loading..." Height="800" Width="400">
    <Grid>
        <Button Content="General"
                Width="120"
                Height="35"
                Click="GeneralLogButton_Click"
                HorizontalAlignment="Center"
                VerticalAlignment="Top" Margin="0,32,0,0"/>
        <Button Content="Warning"
            Width="120"
            Height="35"
            Click="WarningLogButton_Click"
            HorizontalAlignment="Center"
            VerticalAlignment="Top" Margin="0,92,0,0"/>
        <logViewer:LiveLogViewer x:Name="AppLogViewer" Height="220" VerticalAlignment="Bottom" ShowTimeColumn="False" />
        <Button Content="Error Log"
            Width="120"
            Height="35"
            Click="ErrorLogButton_Click"
            HorizontalAlignment="Center"
            VerticalAlignment="Top" Margin="0,163,0,0"/>
    </Grid>
</Window>